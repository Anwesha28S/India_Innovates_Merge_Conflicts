# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/signalsync

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# App
APP_ENV=development
SECRET_KEY=change_me_in_production
CORS_ORIGINS=["http://localhost:3000"]

# ML Service
ML_SERVICE_URL=http://localhost:8001
VISION_CONFIDENCE_THRESHOLD=0.85

# Signal timing defaults (seconds)
DEFAULT_GREEN_DURATION=30
DEFAULT_YELLOW_DURATION=3
DEFAULT_RED_DURATION=30
GREEN_CORRIDOR_ADVANCE_SEC=30
